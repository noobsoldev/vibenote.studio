<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
<title>Sign Up Free — Vibenote.studio</title>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{--gold:#c9a84c;--bg:#080808;--s1:#111;--border:rgba(255,255,255,0.08);--text:#f0ebe0;--muted:rgba(240,235,224,0.45);--green:#52c97a}
body{background:var(--bg);color:var(--text);font-family:'Poppins',sans-serif;min-height:100vh;display:flex;align-items:center;justify-content:center;padding:20px}
.wrap{width:100%;max-width:420px}
.logo{text-align:center;font-size:18px;font-weight:700;margin-bottom:28px}
.logo span{color:var(--gold)}
.card{background:var(--s1);border:1px solid var(--border);border-radius:16px;padding:36px}
h1{font-size:20px;font-weight:700;margin-bottom:6px}
.sub{color:var(--muted);font-size:13px;margin-bottom:18px}
/* Freemium perks */
.perks{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:24px}
.perk{font-size:11px;font-weight:600;padding:4px 10px;border-radius:20px;background:rgba(201,168,76,0.08);border:1px solid rgba(201,168,76,0.2);color:var(--gold)}
/* Google button */
.btn-google{display:flex;align-items:center;justify-content:center;gap:10px;width:100%;padding:13px 20px;background:#fff;color:#1a1a1a;border:none;border-radius:10px;font-size:14px;font-weight:600;cursor:pointer;font-family:'Poppins',sans-serif;transition:box-shadow .2s,transform .1s}
.btn-google:hover{box-shadow:0 4px 20px rgba(255,255,255,0.15);transform:translateY(-1px)}
.btn-google svg{width:18px;height:18px;flex-shrink:0}
/* Divider */
.div{display:flex;align-items:center;gap:12px;margin:18px 0;color:var(--muted);font-size:12px}
.div::before,.div::after{content:'';flex:1;height:1px;background:var(--border)}
/* Fields */
.field{margin-bottom:12px}
label{display:block;font-size:12px;color:var(--muted);margin-bottom:5px;font-weight:500}
input[type=text],input[type=email],input[type=password]{width:100%;padding:12px 14px;background:rgba(255,255,255,0.04);border:1px solid var(--border);border-radius:8px;color:var(--text);font-family:'Poppins',sans-serif;font-size:14px;outline:none;transition:.2s}
input:focus{border-color:var(--gold);background:rgba(201,168,76,0.04)}
/* Primary button */
.btn-primary{width:100%;padding:13px;background:var(--gold);color:#080808;border:none;border-radius:10px;font-size:14px;font-weight:700;cursor:pointer;font-family:'Poppins',sans-serif;margin-top:6px;transition:background .15s}
.btn-primary:hover{background:#d4b060}
.btn-primary:disabled{opacity:.6;cursor:not-allowed}
/* Freemium note */
.freenote{margin-top:18px;padding:14px;background:rgba(201,168,76,0.05);border:1px solid rgba(201,168,76,0.15);border-radius:10px;font-size:12px;color:var(--muted);line-height:1.7;text-align:center}
.freenote strong{color:var(--gold)}
/* Error / success */
.err{background:rgba(224,92,92,0.1);border:1px solid rgba(224,92,92,0.3);color:#ff8080;border-radius:8px;padding:12px;font-size:13px;margin-bottom:14px;display:none}
.success-card{text-align:center;padding:20px 0}
.success-icon{font-size:44px;margin-bottom:16px}
/* Footer links */
.flink{text-align:center;margin-top:18px;font-size:13px;color:var(--muted)}
.flink a{color:var(--gold);text-decoration:none}
/* Loading */
.loading{display:none;position:fixed;inset:0;background:rgba(8,8,8,0.85);z-index:999;align-items:center;justify-content:center;flex-direction:column;gap:14px}
.loading.show{display:flex}
.spinner{width:36px;height:36px;border:3px solid rgba(201,168,76,0.2);border-top-color:var(--gold);border-radius:50%;animation:spin .7s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.loading p{color:var(--muted);font-size:14px}
</style>
</head>
<body>

<div class="loading" id="loading">
  <div class="spinner"></div>
  <p>Setting up your account...</p>
</div>

<div class="wrap">
  <div class="logo">Vibenote<span>.studio</span></div>
  <div class="card" id="main-card">
    <h1>Start for free</h1>
    <p class="sub">Design your first client website at no cost</p>
    <div class="perks">
      <span class="perk">✓ Free to design</span>
      <span class="perk">✓ No credit card</span>
      <span class="perk">✓ Unlimited brief saves</span>
    </div>

    <div class="err" id="err"></div>

    <button class="btn-google" onclick="signUpGoogle()">
      <svg viewBox="0 0 24 24">
        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
        <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
      </svg>
      Sign up with Google
    </button>

    <div class="div">or sign up with email</div>

    <div class="field"><label>Your Name / Agency Name</label><input type="text" id="name" placeholder="e.g. Noob Dev Technologies" autocomplete="name"></div>
    <div class="field"><label>Email</label><input type="email" id="email" placeholder="you@agency.com" autocomplete="email"></div>
    <div class="field"><label>Password <span style="color:var(--muted);font-weight:400">(min 8 chars)</span></label><input type="password" id="password" placeholder="Choose a strong password" autocomplete="new-password"></div>
    <div class="field"><label>Referral Code <span style="color:var(--muted);font-weight:400">(optional)</span></label><input type="text" id="ref" value="<%= ref %>" placeholder="e.g. VIBENOTE2024" style="text-transform:uppercase"></div>

    <button class="btn-primary" id="emailBtn" onclick="signUpEmail()">Create Free Account →</button>

    <div class="freenote">
      🎨 <strong>Free to design.</strong> AI generates your site — no cost.<br>
      Want to deploy to client hosting? <strong>₹5,000/month</strong> on Starter plan.
    </div>

    <div class="flink">Already have an account? <a href="/login">Sign in</a></div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.js"></script>
<script>
const AUTH_REDIRECT_URL = (window.location.origin || '<%- appUrl %>') + '/auth/callback';
const _supabase = window.supabase.createClient(
  '<%- supabaseUrl %>',
  '<%- supabaseAnonKey %>',
  {
    auth: {
      persistSession: true,
      autoRefreshToken: true,
      detectSessionInUrl: true,
      flowType: 'pkce'
    }
  }
);
let _sessionPosted = false;

function showErr(msg) {
  const el = document.getElementById('err');
  el.textContent = msg;
  el.style.display = 'block';
  el.scrollIntoView({behavior:'smooth',block:'nearest'});
}
function showLoading(show) {
  document.getElementById('loading').classList.toggle('show', show);
}

async function sendSession(session, ref) {
  if (!session || _sessionPosted) return;
  _sessionPosted = true;
  try {
    const r = await fetch('/auth/session', {
      method: 'POST',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify({
        access_token: session.access_token,
        refresh_token: session.refresh_token,
        ref: ref || ''
      })
    });
    const d = await r.json();
    if (d.redirect) { window.location.href = d.redirect; }
    else {
      _sessionPosted = false;
      showLoading(false);
      showErr(d.error || 'Signup failed. Please try again.');
    }
  } catch(e) {
    _sessionPosted = false;
    showLoading(false);
    showErr('Network error. Please try again.');
  }
}

async function signUpGoogle() {
  showLoading(true);
  const ref = document.getElementById('ref')?.value || '';
  sessionStorage.setItem('signup_ref', ref);
  const { error } = await _supabase.auth.signInWithOAuth({
    provider: 'google',
    options: {
      redirectTo: AUTH_REDIRECT_URL,
      queryParams: { access_type: 'offline', prompt: 'consent' }
    }
  });
  if (error) {
    showLoading(false);
    if (error.message?.includes('provider') || error.message?.includes('not enabled')) {
      showErr('Google sign-in is being set up. Please use email signup for now.');
    } else {
      showErr(error.message);
    }
  }
}

_supabase.auth.onAuthStateChange((event, session) => {
  if (session && (event === 'INITIAL_SESSION' || event === 'SIGNED_IN' || event === 'TOKEN_REFRESHED')) {
    showLoading(true);
    sendSession(session, sessionStorage.getItem('signup_ref') || '');
  }
});

window.addEventListener('load', async () => {
  const { data } = await _supabase.auth.getSession();
  if (data?.session) {
    showLoading(true);
    await sendSession(data.session, sessionStorage.getItem('signup_ref') || '');
  }
});

async function signUpEmail() {
  const name = document.getElementById('name').value.trim();
  const email = document.getElementById('email').value.trim();
  const password = document.getElementById('password').value;
  const ref = document.getElementById('ref').value.trim();

  if (!name) return showErr('Please enter your name or agency name.');
  if (!email) return showErr('Please enter your email address.');
  if (password.length < 8) return showErr('Password must be at least 8 characters.');

  const btn = document.getElementById('emailBtn');
  btn.disabled = true;
  btn.textContent = 'Creating account...';

  const { data, error } = await _supabase.auth.signUp({
    email, password,
    options: {
      data: { full_name: name },
      emailRedirectTo: AUTH_REDIRECT_URL
    }
  });

  if (error) {
    btn.disabled = false;
    btn.textContent = 'Create Free Account →';
    return showErr(error.message);
  }

  if (data.session) {
    showLoading(true);
    await sendSession(data.session, ref);
  } else {
    // Email confirmation needed
    document.getElementById('main-card').innerHTML = `
      <div class="success-card">
        <div class="success-icon">📧</div>
        <h2 style="margin-bottom:10px">Check your inbox</h2>
        <p style="color:var(--muted);font-size:14px;line-height:1.7">
          We sent a confirmation link to<br>
          <strong style="color:var(--text)">${email}</strong>
        </p>
        <p style="color:var(--muted);font-size:12px;margin-top:16px">
          Click the link in the email to activate your account, then <a href="/login" style="color:var(--gold)">sign in here</a>.
        </p>
      </div>`;
  }
}
</script>
</body>
</html>
