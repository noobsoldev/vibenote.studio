<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sign Up — Vibenote.studio</title>
<link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="auth-page">
  <div class="auth-box" style="max-width:460px">
    <div class="auth-logo">Vibenote<span>.studio</span></div>
    <div class="auth-subtitle">AI Website Builder</div>
    <div class="auth-title">Create agency account</div>
    <div class="auth-desc">You need a referral code from an existing member to join.</div>

    <% if (error) { %>
    <div class="alert alert-error">⚠ <%= error %></div>
    <% } %>

    <form method="POST" action="/signup">
      <div class="form-group">
        <label class="form-label">Agency Name <span class="req">*</span></label>
        <input type="text" name="name" class="form-control" placeholder="e.g. Noob{Dev} Technologies" required>
      </div>
      <div class="form-group">
        <label class="form-label">Email Address <span class="req">*</span></label>
        <input type="email" name="email" class="form-control" placeholder="hello@agency.com" required autocomplete="email">
      </div>
      <div class="form-group">
        <label class="form-label">Password <span class="req">*</span></label>
        <input type="password" name="password" class="form-control" placeholder="Minimum 8 characters" required minlength="8" autocomplete="new-password">
      </div>
      <div class="form-group">
        <label class="form-label">Referral Code <span class="req">*</span></label>
        <input type="text" name="referral_code" class="form-control" placeholder="Enter your invite code" value="<%= ref %>" required style="text-transform:uppercase;letter-spacing:0.08em;">
        <div class="form-hint">Required — get this from an existing Vibenote member.</div>
      </div>
      <button type="submit" class="btn btn-gold btn-block" style="margin-top:8px">Create Account →</button>
    </form>

    <div class="auth-divider"><span>or</span></div>
    <div class="auth-footer">
      Already have an account? <a href="/login">Sign in</a>
    </div>
  </div>
</div>
</body>
</html>
