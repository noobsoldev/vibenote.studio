<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
<title>Admin — Vibenote.studio</title>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{--gold:#c9a84c;--bg:#0a0a0a;--surface:#111;--border:#1e1e1e;--text:#e8e8e8;--muted:#555;--dim:#888}
body{background:var(--bg);color:var(--text);font-family:'Poppins',sans-serif;min-height:100vh}
.topnav{display:flex;align-items:center;justify-content:space-between;padding:0 32px;height:60px;border-bottom:1px solid var(--border);background:var(--surface)}
.logo{font-size:16px;font-weight:700}.logo span{color:var(--gold)}
.badge{padding:4px 10px;border-radius:20px;font-size:11px;font-weight:600;background:#2d1a00;color:var(--gold)}
a.logout{color:var(--muted);font-size:13px;text-decoration:none}
.wrap{max-width:1300px;margin:0 auto;padding:32px}
h2{font-size:20px;font-weight:700;margin-bottom:20px}
.kpi-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:16px;margin-bottom:32px}
.kpi{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:20px}
.kpi-label{font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;margin-bottom:6px}
.kpi-val{font-size:28px;font-weight:700;color:var(--gold)}
.kpi-sub{font-size:11px;color:var(--dim);margin-top:4px}
.plan-breakdown{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:32px}
.plan-pill{padding:6px 14px;border-radius:20px;font-size:12px;font-weight:600;border:1px solid var(--border)}
.plan-pill.free{background:#1a1a1a;color:#888}
.plan-pill.starter{background:#0d1a2d;color:#6ab0ff}
.plan-pill.growth{background:#1a2d0d;color:#7dcc5a}
.plan-pill.agency{background:#2d1a00;color:var(--gold)}
.section{margin-bottom:36px}
.section-title{font-size:14px;font-weight:600;color:var(--dim);text-transform:uppercase;letter-spacing:.5px;margin-bottom:14px}
table{width:100%;border-collapse:collapse;font-size:13px}
th{text-align:left;padding:10px 14px;border-bottom:1px solid var(--border);color:var(--muted);font-weight:500;font-size:11px;text-transform:uppercase;letter-spacing:.5px}
td{padding:12px 14px;border-bottom:1px solid #161616;vertical-align:middle}
tr:hover td{background:#0f0f0f}
.status-active{color:#7dcc5a}.status-suspended{color:#ff7070}
.badge-plan{padding:3px 8px;border-radius:10px;font-size:10px;font-weight:600}
.badge-free{background:#1a1a1a;color:#666}
.badge-starter{background:#0d1a2d;color:#6ab0ff}
.badge-growth{background:#1a2d0d;color:#7dcc5a}
.badge-agency{background:#2d1a00;color:var(--gold)}
.ind-tags{display:flex;gap:4px;flex-wrap:wrap}
.ind-tag{background:#1a1a1a;border:1px solid var(--border);padding:2px 8px;border-radius:10px;font-size:10px;color:var(--dim)}
.search{padding:10px 14px;background:#1a1a1a;border:1px solid var(--border);border-radius:8px;color:var(--text);font-family:'Poppins',sans-serif;font-size:13px;outline:none;width:280px;margin-bottom:16px}
.search:focus{border-color:var(--gold)}
.industries-chart{display:flex;flex-direction:column;gap:8px;max-width:500px}
.ind-row{display:flex;align-items:center;gap:10px;font-size:13px}
.ind-bar-wrap{flex:1;background:#1a1a1a;border-radius:4px;height:8px;overflow:hidden}
.ind-bar{height:100%;background:var(--gold);border-radius:4px}
.ind-count{font-size:11px;color:var(--muted);min-width:24px;text-align:right}
</style>
</head>
<body>
<nav class="topnav">
  <div class="logo">Vibenote<span>.studio</span> <span class="badge">Admin</span></div>
  <a class="logout" href="/admin/logout">Sign out</a>
</nav>

<div class="wrap">
  <h2>Agency Overview</h2>

  <!-- KPIs -->
  <div class="kpi-grid">
    <div class="kpi">
      <div class="kpi-label">Total Agencies</div>
      <div class="kpi-val"><%= summary.total %></div>
      <div class="kpi-sub"><%= summary.active %> active</div>
    </div>
    <div class="kpi">
      <div class="kpi-label">Sites Generated</div>
      <div class="kpi-val"><%= summary.totalSites %></div>
      <div class="kpi-sub">across all accounts</div>
    </div>
    <div class="kpi">
      <div class="kpi-label">Paying Agencies</div>
      <div class="kpi-val"><%= (summary.byPlan.starter||0)+(summary.byPlan.growth||0)+(summary.byPlan.agency||0) %></div>
      <div class="kpi-sub">starter + growth + agency</div>
    </div>
    <div class="kpi">
      <div class="kpi-label">Est. Monthly Revenue</div>
      <div class="kpi-val">₹<%= ((summary.byPlan.starter||0)*5000+(summary.byPlan.growth||0)*40000+(summary.byPlan.agency||0)*150000).toLocaleString('en-IN') %></div>
      <div class="kpi-sub">based on active plans</div>
    </div>
  </div>

  <!-- Plan breakdown -->
  <div class="plan-breakdown">
    <span class="plan-pill free">Free: <%= summary.byPlan.free||0 %></span>
    <span class="plan-pill starter">Starter: <%= summary.byPlan.starter||0 %></span>
    <span class="plan-pill growth">Growth: <%= summary.byPlan.growth||0 %></span>
    <span class="plan-pill agency">Agency: <%= summary.byPlan.agency||0 %></span>
  </div>

  <!-- Industries chart -->
  <% const indEntries = Object.entries(summary.topIndustries).sort((a,b)=>b[1]-a[1]).slice(0,8);
     const maxInd = indEntries[0]?.[1] || 1; %>
  <% if (indEntries.length > 0) { %>
  <div class="section">
    <div class="section-title">Top Industries Being Built</div>
    <div class="industries-chart">
      <% for (const [ind, count] of indEntries) { %>
      <div class="ind-row">
        <span style="min-width:140px;color:var(--text);font-size:12px"><%= ind %></span>
        <div class="ind-bar-wrap"><div class="ind-bar" style="width:<%= Math.round((count/maxInd)*100) %>%"></div></div>
        <span class="ind-count"><%= count %></span>
      </div>
      <% } %>
    </div>
  </div>
  <% } %>

  <!-- Recent projects -->
  <% if (recentProjects.length > 0) { %>
  <div class="section">
    <div class="section-title">Recent Activity</div>
    <table>
      <thead><tr><th>Client</th><th>Industry</th><th>Status</th><th>Date</th></tr></thead>
      <tbody>
      <% for (const p of recentProjects) { %>
      <tr>
        <td><%= p.client_name %></td>
        <td><%= p.industry || '—' %></td>
        <td><%= p.status %></td>
        <td style="color:var(--muted)"><%= new Date(p.created_at).toLocaleDateString('en-IN') %></td>
      </tr>
      <% } %>
      </tbody>
    </table>
  </div>
  <% } %>

  <!-- All agencies -->
  <div class="section">
    <div class="section-title">All Agencies</div>
    <input class="search" type="text" id="search" placeholder="Search by name or email..." onkeyup="filterTable()">
    <table id="agency-table">
      <thead><tr><th>Agency</th><th>Email</th><th>Plan</th><th>Credits</th><th>Sites</th><th>Industries</th><th>Country</th><th>Status</th><th>Joined</th></tr></thead>
      <tbody>
      <% for (const a of agencies) { %>
      <tr>
        <td style="font-weight:500"><%= a.name %></td>
        <td style="color:var(--muted)"><%= a.email %></td>
        <td><span class="badge-plan badge-<%= a.plan %>"><%= a.plan %></span></td>
        <td style="color:var(--dim)"><%= a.site_credits %></td>
        <td><%= a.sites_generated||0 %> gen / <%= a.sites_live||0 %> live</td>
        <td>
          <div class="ind-tags">
            <% for (const ind of (a.industries||[]).slice(0,3)) { %>
              <% if(ind) { %><span class="ind-tag"><%= ind %></span><% } %>
            <% } %>
          </div>
        </td>
        <td style="color:var(--dim)"><%= a.country||'IN' %></td>
        <td class="status-<%= a.status %>"><%= a.status %></td>
        <td style="color:var(--muted)"><%= new Date(a.created_at).toLocaleDateString('en-IN') %></td>
      </tr>
      <% } %>
      </tbody>
    </table>
  </div>
</div>

<script>
function filterTable() {
  const q = document.getElementById('search').value.toLowerCase();
  document.querySelectorAll('#agency-table tbody tr').forEach(row => {
    row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
  });
}
</script>
</body>
</html>
