<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Login — Vibenote.studio</title>
<link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="auth-page">
  <div class="auth-box">
    <div class="auth-logo">Vibenote<span>.studio</span></div>
    <div class="auth-subtitle">AI Website Builder</div>
    <div class="auth-title">Welcome back</div>
    <div class="auth-desc">Sign in to your agency dashboard.</div>

    <% if (error) { %>
    <div class="alert alert-error">⚠ <%= error %></div>
    <% } %>

    <form method="POST" action="/login">
      <input type="hidden" name="next" value="<%= next %>">
      <div class="form-group">
        <label class="form-label">Email Address</label>
        <input type="email" name="email" class="form-control" placeholder="hello@agency.com" required autocomplete="email">
      </div>
      <div class="form-group">
        <label class="form-label">Password</label>
        <input type="password" name="password" class="form-control" placeholder="••••••••" required autocomplete="current-password">
      </div>
      <button type="submit" class="btn btn-gold btn-block" style="margin-top:8px">Sign In →</button>
    </form>

    <div class="auth-divider"><span>or</span></div>
    <div class="auth-footer">
      Don't have an account? <a href="/signup">Request Access</a>
    </div>
  </div>
</div>
</body>
</html>
