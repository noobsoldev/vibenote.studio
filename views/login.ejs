<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
<title>Sign In - Vibenote.studio</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{--gold:#c9a84c;--bg:#080808;--s1:#111;--border:rgba(255,255,255,0.08);--text:#f0ebe0;--muted:rgba(240,235,224,0.45)}
body{background:var(--bg);color:var(--text);font-family:'Poppins',sans-serif;min-height:100vh;display:flex;align-items:center;justify-content:center;padding:20px}
.wrap{width:100%;max-width:400px}.logo{text-align:center;font-size:18px;font-weight:700;margin-bottom:32px;color:var(--text)}.logo span{color:var(--gold)}
.card{background:var(--s1);border:1px solid var(--border);border-radius:16px;padding:36px}
h1{font-size:20px;font-weight:700;margin-bottom:4px}.sub{color:var(--muted);font-size:13px;margin-bottom:28px}
.btn-google{display:flex;align-items:center;justify-content:center;gap:10px;width:100%;padding:13px 20px;background:#fff;color:#1a1a1a;border:none;border-radius:10px;font-size:14px;font-weight:600;cursor:pointer;font-family:'Poppins',sans-serif;transition:box-shadow .2s,transform .1s}
.btn-google:hover{box-shadow:0 4px 20px rgba(255,255,255,0.15);transform:translateY(-1px)}.btn-google:active{transform:translateY(0)}.btn-google svg{width:18px;height:18px;flex-shrink:0}
.div{display:flex;align-items:center;gap:12px;margin:20px 0;color:var(--muted);font-size:12px}.div::before,.div::after{content:'';flex:1;height:1px;background:var(--border)}
.field{margin-bottom:14px}label{display:block;font-size:12px;color:var(--muted);margin-bottom:5px;font-weight:500;letter-spacing:.3px}
input[type=email],input[type=password]{width:100%;padding:12px 14px;background:rgba(255,255,255,0.04);border:1px solid var(--border);border-radius:8px;color:var(--text);font-family:'Poppins',sans-serif;font-size:14px;outline:none;transition:.2s}
input:focus{border-color:var(--gold);background:rgba(201,168,76,0.04)}
.btn-primary{width:100%;padding:13px;background:var(--gold);color:#080808;border:none;border-radius:10px;font-size:14px;font-weight:700;cursor:pointer;font-family:'Poppins',sans-serif;margin-top:6px;transition:background .15s,transform .1s}
.btn-primary:hover{background:#d4b060}.btn-primary:active{transform:scale(0.99)}.btn-primary:disabled{opacity:.6;cursor:not-allowed}
.err{background:rgba(224,92,92,0.1);border:1px solid rgba(224,92,92,0.3);color:#ff8080;border-radius:8px;padding:12px;font-size:13px;margin-bottom:16px}
.flink{text-align:center;margin-top:20px;font-size:13px;color:var(--muted)}.flink a{color:var(--gold);text-decoration:none}.flink a:hover{text-decoration:underline}
.loading{display:none;position:fixed;inset:0;background:rgba(8,8,8,0.85);z-index:999;align-items:center;justify-content:center;flex-direction:column;gap:14px}.loading.show{display:flex}
.spinner{width:36px;height:36px;border:3px solid rgba(201,168,76,0.2);border-top-color:var(--gold);border-radius:50%;animation:spin .7s linear infinite}@keyframes spin{to{transform:rotate(360deg)}}.loading p{color:var(--muted);font-size:14px}
</style>
</head>
<body>
<div class="loading" id="loading"><div class="spinner"></div><p>Signing you in...</p></div>
<div class="wrap">
  <div class="logo">Vibenote<span>.studio</span></div>
  <div class="card">
    <h1>Welcome back</h1>
    <p class="sub">Sign in to your agency account</p>

    <% if (errorMessage) { %>
    <div class="err"><%= errorMessage %></div>
    <% } %>

    <button class="btn-google" type="button" id="google-login-btn">
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
        <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
      </svg>
      Continue with Google
    </button>

    <div class="div">or</div>

    <form method="POST" action="/login" id="email-login-form">
      <div class="field">
        <label>Email</label>
        <input type="email" name="email" placeholder="you@agency.com" autocomplete="email" required>
      </div>
      <div class="field">
        <label>Password</label>
        <input type="password" name="password" placeholder="••••••••" autocomplete="current-password" required>
      </div>
      <button class="btn-primary" type="submit" id="email-login-btn">Sign In</button>
    </form>

    <div class="flink" style="margin-top:16px">No account? <a href="/signup">Create one free</a></div>
    <div class="flink" style="margin-top:8px"><a href="/" style="color:var(--muted);font-size:12px">? Back to home</a></div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.js"></script>
<script>
const supabaseUrl = '<%- supabaseUrl %>';
const supabaseKey = '<%- supabaseAnonKey %>';
const fallbackBaseUrl = '<%- baseUrl %>';
const authRedirectUrl = (window.location.origin || fallbackBaseUrl) + '/auth/callback';
const loading = document.getElementById('loading');
const googleBtn = document.getElementById('google-login-btn');
const emailForm = document.getElementById('email-login-form');
const emailBtn = document.getElementById('email-login-btn');

function showLoginError(message) {
  const current = document.querySelector('.err');
  if (current) {
    current.textContent = message;
    current.style.display = 'block';
    return;
  }

  const errorEl = document.createElement('div');
  errorEl.className = 'err';
  errorEl.textContent = message;
  const card = document.querySelector('.card');
  const heading = card ? card.querySelector('h1') : null;
  if (card && heading) {
    heading.insertAdjacentElement('afterend', errorEl);
  }
}

function buildSupabaseClient() {
  if (!window.supabase || !window.supabase.createClient) {
    showLoginError('Login SDK failed to load. Please refresh and try again.');
    return null;
  }

  if (!supabaseUrl || !supabaseKey) {
    showLoginError('Login is not configured correctly on the server.');
    return null;
  }

  return window.supabase.createClient(supabaseUrl, supabaseKey, {
    auth: {
      persistSession: true,
      autoRefreshToken: true,
      detectSessionInUrl: true,
      flowType: 'pkce'
    }
  });
}

const authClient = buildSupabaseClient();

async function loginWithGoogle() {
  if (!authClient) return;
  loading.classList.add('show');
  googleBtn.disabled = true;

  try {
    const { error } = await authClient.auth.signInWithOAuth({
      provider: 'google',
      options: {
        redirectTo: authRedirectUrl,
        queryParams: {
          access_type: 'offline',
          prompt: 'consent'
        }
      }
    });

    if (error) {
      console.error('OAuth error:', error);
      loading.classList.remove('show');
      googleBtn.disabled = false;
      showLoginError(error.message || 'Google sign-in failed. Please try again.');
    }
  } catch (error) {
    console.error('OAuth exception:', error);
    loading.classList.remove('show');
    googleBtn.disabled = false;
    showLoginError('Google sign-in failed. Please try again.');
  }
}

if (googleBtn) {
  googleBtn.addEventListener('click', loginWithGoogle);
}

if (emailForm) {
  emailForm.addEventListener('submit', () => {
    loading.classList.add('show');
    if (emailBtn) {
      emailBtn.disabled = true;
      emailBtn.textContent = 'Signing In...';
    }
  });
}
</script>
</body>
</html>

