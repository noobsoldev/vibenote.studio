<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= project.client_name %> - Editor | VibeNote.studio</title>
<link rel="stylesheet" href="/css/style.css">
<style>
body { overflow: hidden; }
.editor-layout { height: calc(100vh - 56px); }
</style>
</head>
<body>

<nav class="topnav">
  <a href="/dashboard" class="topnav-logo" style="text-decoration:none">&larr; VibeNote<span>.studio</span></a>
  <div class="topnav-right">
    <span class="badge badge-<%= project.status %>"><%= project.status %></span>
    <% if (project.deployment_url) { %>
    <a href="<%= project.deployment_url %>" target="_blank" class="btn btn-ghost btn-sm">Live</a>
    <% } %>
  </div>
</nav>

<div class="editor-layout">
  <div class="editor-preview">
    <div class="editor-toolbar">
      <input class="editor-toolbar-sitename" id="siteNameInput" value="<%= project.client_name %>">
      <div class="toolbar-sep"></div>
      <button class="btn btn-ghost btn-sm" onclick="regenerateSite()">Regenerate</button>
      <div class="toolbar-right">
        <button id="redeployBtn" class="btn btn-outline btn-sm" style="display:none" onclick="showDeployModal()">Redeploy</button>
        <button class="btn btn-ghost btn-sm" onclick="downloadHtml(<%= project.id %>)">Export HTML</button>
        <button class="btn btn-gold btn-sm" onclick="showDeployModal()">Deploy</button>
      </div>
    </div>
    <iframe class="preview-frame" id="previewFrame" src="/generate/<%= project.id %>/html" sandbox="allow-scripts allow-same-origin"></iframe>
  </div>

  <aside class="editor-sidebar">
    <div class="sidebar-header">
      <div class="sidebar-project-name"><%= project.client_name %></div>
      <div class="sidebar-project-status"><%= formData.industry || 'Client website' %> | <%= project.status %></div>
    </div>

    <div class="chat-messages" id="chatMessages">
      <% chatHistory.forEach(msg => { %>
      <div class="chat-bubble bubble-<%= msg.role === 'user' ? 'user' : 'ai' %>">
        <% if (msg.role === 'assistant') { %>
        <div class="bubble-ai-label">VibeNote AI</div>
        <% } %>
        <%- msg.message %>
      </div>
      <% }); %>
      <% if (chatHistory.length === 0) { %>
      <div class="chat-bubble bubble-ai">
        <div class="bubble-ai-label">VibeNote AI</div>
        Client website generated for <strong><%= project.client_name %></strong>. Ask for changes like "tighten the hero copy", "add a FAQ", or "switch the accent color to dark green".
      </div>
      <% } %>
    </div>

    <div class="chat-input-area">
      <div class="chat-input-row">
        <textarea class="chat-textarea" id="chatInput" data-project-id="<%= project.id %>" placeholder="Describe the next client-facing edit..." rows="1"></textarea>
        <button class="chat-send-btn" id="chatSendBtn" onclick="sendChatMessage(<%= project.id %>)" title="Send"></button>
      </div>
      <div class="chat-hint">Press Enter to send | Shift+Enter for a new line</div>
    </div>
  </aside>
</div>

<div class="modal-overlay" id="deployModal">
  <div class="modal">
    <div class="modal-title">Deploy Client Website</div>
    <div class="modal-desc">Publish <strong><%= project.client_name %></strong> and return a live URL.</div>
    <div style="margin-bottom:14px">
      <label class="form-label">Deploy Target</label>
      <select class="form-control" id="deployProvider">
        <option value="sftp">SFTP</option>
        <option value="cloudflare">Cloudflare Pages</option>
        <option value="export_html">Export HTML</option>
      </select>
    </div>
    <div class="deploy-steps" id="deploySteps">
      <div class="deploy-step pending" id="dstep_0"><span class="step-icon">o</span> Preparing static site bundle...</div>
      <div class="deploy-step pending" id="dstep_1"><span class="step-icon">o</span> Connecting to deploy target...</div>
      <div class="deploy-step pending" id="dstep_2"><span class="step-icon">o</span> Uploading files...</div>
      <div class="deploy-step pending" id="dstep_3"><span class="step-icon">o</span> Returning live URL...</div>
    </div>
    <div id="deployUrl"></div>
    <div class="modal-footer">
      <button class="btn btn-ghost btn-sm" onclick="downloadHtml(<%= project.id %>)">Export HTML Instead</button>
      <button class="btn btn-ghost btn-sm" id="deployCloseBtn" onclick="hideDeployModal()">Close</button>
      <button class="btn btn-gold btn-sm" id="deployStartBtn" onclick="startDeploy()">Deploy Now</button>
    </div>
  </div>
</div>

<script src="/js/main.js"></script>
<script>
initEditor(<%= project.id %>);

async function regenerateSite() {
  if (!confirm('Regenerate will use 1 site slot and replace the current website. Continue?')) return;
  const overlay = document.createElement('div');
  overlay.style.cssText = 'position:fixed;inset:0;background:rgba(10,10,10,0.9);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:16px;z-index:2000';
  overlay.innerHTML = '<div class="spinner"></div><div style="font-size:14px;font-weight:600">Regenerating client website...</div>';
  document.body.appendChild(overlay);
  try {
    const res = await fetch('/generate/<%= project.id %>', { method: 'POST' });
    const data = await res.json();
    if (data.success) {
      document.getElementById('previewFrame').src = '/generate/<%= project.id %>/html?t=' + Date.now();
    } else {
      showToast(data.error || 'Regeneration failed', 'error');
    }
  } catch (e) {
    showToast('Network error', 'error');
  }
  overlay.remove();
}

let deployStarted = false;
function startDeploy() {
  if (deployStarted) return;
  deployStarted = true;
  document.getElementById('deployStartBtn').style.display = 'none';
  deployProject(<%= project.id %>).then(() => {
    deployStarted = false;
    document.getElementById('deployStartBtn').style.display = 'inline-flex';
  });
}

document.getElementById('deployModal').addEventListener('click', function(e) {
  if (e.target === this) hideDeployModal();
});
</script>
</body>
</html>
