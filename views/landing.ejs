<!DOCTYPE html>
<html lang="en">
<head>
<%- include('layout', { seo, baseUrl }) %>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#0a0d12;
  --panel:#121722;
  --panel-2:#171d2a;
  --line:rgba(255,255,255,.09);
  --text:#f5f7fb;
  --muted:#9ea8bb;
  --gold:#d7b35d;
  --gold-2:#f0d48f;
  --green:#6ce0a6;
  --red:#ff8a8a;
  --max:1180px;
  --r:22px;
}
html{scroll-behavior:smooth}
body{
  font-family:'Manrope',sans-serif;
  background:
    radial-gradient(circle at top left, rgba(215,179,93,.12), transparent 28%),
    radial-gradient(circle at top right, rgba(108,224,166,.08), transparent 22%),
    linear-gradient(180deg,#0a0d12 0%,#0d1118 100%);
  color:var(--text);
  line-height:1.6;
}
a{text-decoration:none;color:inherit}
.wrap{max-width:var(--max);margin:0 auto;padding:0 24px}
nav{
  position:sticky;top:0;z-index:20;
  backdrop-filter:blur(18px);
  background:rgba(10,13,18,.78);
  border-bottom:1px solid var(--line);
}
.nav-in{height:74px;display:flex;align-items:center;justify-content:space-between}
.logo{font-size:20px;font-weight:800;letter-spacing:-.04em}
.logo span{color:var(--gold)}
.nav-links{display:flex;gap:22px;color:var(--muted);font-size:14px}
.nav-actions{display:flex;gap:10px}
.btn{
  display:inline-flex;align-items:center;justify-content:center;
  min-height:46px;padding:0 18px;border-radius:999px;font-size:14px;font-weight:700;
  border:1px solid transparent;transition:.18s ease;
}
.btn-primary{background:var(--gold);color:#111}
.btn-primary:hover{background:var(--gold-2)}
.btn-secondary{border-color:var(--line);background:rgba(255,255,255,.03)}
.btn-secondary:hover{border-color:rgba(215,179,93,.35);background:rgba(215,179,93,.08)}
section{padding:88px 0}
.hero{padding:84px 0 56px}
.hero-grid{
  display:grid;grid-template-columns:1.15fr .85fr;gap:26px;align-items:center;
}
.eyebrow{
  display:inline-flex;align-items:center;gap:10px;padding:8px 14px;border-radius:999px;
  background:rgba(215,179,93,.1);border:1px solid rgba(215,179,93,.22);
  color:var(--gold);font-size:12px;font-weight:800;text-transform:uppercase;letter-spacing:.12em;
}
.eyebrow::before{content:'';width:8px;height:8px;border-radius:50%;background:var(--gold)}
h1{font-size:clamp(42px,7vw,78px);line-height:1.03;letter-spacing:-.06em;margin:20px 0}
.hero p{font-size:18px;color:var(--muted);max-width:690px}
.hero-actions{display:flex;gap:12px;flex-wrap:wrap;margin:28px 0 18px}
.mini-row{display:flex;gap:10px;flex-wrap:wrap;color:var(--muted);font-size:13px}
.mini-pill{
  border:1px solid var(--line);background:rgba(255,255,255,.03);
  border-radius:999px;padding:8px 12px
}
.hero-card{
  background:linear-gradient(180deg,rgba(255,255,255,.05),rgba(255,255,255,.02));
  border:1px solid var(--line);border-radius:28px;padding:22px;box-shadow:0 20px 60px rgba(0,0,0,.25)
}
.dashboard-preview{display:grid;gap:14px}
.preview-top,.preview-list,.preview-math{background:var(--panel);border:1px solid var(--line);border-radius:20px}
.preview-top{padding:18px}
.preview-top h3{font-size:15px;margin-bottom:14px}
.stat-row{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}
.stat{
  background:var(--panel-2);border:1px solid var(--line);border-radius:16px;padding:14px
}
.stat-label{font-size:11px;text-transform:uppercase;letter-spacing:.12em;color:var(--muted)}
.stat-value{font-size:28px;font-weight:800;margin-top:8px}
.preview-list{padding:18px}
.project-row{
  display:flex;align-items:center;justify-content:space-between;
  padding:14px 0;border-bottom:1px solid var(--line)
}
.project-row:last-child{border-bottom:none}
.project-meta strong{display:block;font-size:15px}
.project-meta span{color:var(--muted);font-size:13px}
.badge{
  font-size:11px;font-weight:800;text-transform:uppercase;letter-spacing:.1em;
  padding:8px 12px;border-radius:999px;border:1px solid var(--line)
}
.badge.generated{color:var(--gold);background:rgba(215,179,93,.09)}
.badge.editing{color:#9dccff;background:rgba(93,155,255,.1)}
.badge.live{color:var(--green);background:rgba(108,224,166,.1)}
.preview-math{padding:18px}
.preview-math p{font-size:14px;color:var(--muted)}
.preview-math strong{color:var(--text)}
.section-head{display:flex;justify-content:space-between;gap:24px;align-items:end;margin-bottom:26px}
.section-head h2{font-size:clamp(30px,4vw,46px);line-height:1.06;letter-spacing:-.05em}
.section-head p{max-width:560px;color:var(--muted)}
.grid-2,.grid-3,.grid-4{display:grid;gap:16px}
.grid-2{grid-template-columns:repeat(2,1fr)}
.grid-3{grid-template-columns:repeat(3,1fr)}
.grid-4{grid-template-columns:repeat(4,1fr)}
.card{
  background:rgba(18,23,34,.86);border:1px solid var(--line);border-radius:var(--r);padding:24px
}
.card h3{font-size:20px;margin-bottom:8px}
.card p{color:var(--muted);font-size:14px}
.type-card{min-height:170px}
.icon{
  width:46px;height:46px;border-radius:14px;display:flex;align-items:center;justify-content:center;
  background:rgba(215,179,93,.1);border:1px solid rgba(215,179,93,.2);margin-bottom:16px;font-size:22px
}
.not-for .card{border-color:rgba(255,138,138,.14)}
.not-for .icon{background:rgba(255,138,138,.08);border-color:rgba(255,138,138,.18)}
.workflow{
  display:grid;grid-template-columns:repeat(4,1fr);gap:16px
}
.step{
  position:relative;padding-top:18px
}
.step-num{
  width:42px;height:42px;border-radius:50%;display:flex;align-items:center;justify-content:center;
  background:var(--gold);color:#111;font-weight:800;margin-bottom:18px
}
.step h3{font-size:18px;margin-bottom:8px}
.stack-note{
  margin-top:22px;padding:20px 24px;border-radius:20px;
  background:rgba(108,224,166,.06);border:1px solid rgba(108,224,166,.16);color:#d8f9e9
}
.pricing-wrap{display:grid;grid-template-columns:repeat(2,1fr);gap:18px}
.price-card{position:relative}
.price-card.popular{border-color:rgba(215,179,93,.45);box-shadow:0 18px 50px rgba(215,179,93,.08)}
.popular-tag{
  position:absolute;top:18px;right:18px;background:var(--gold);color:#111;
  padding:7px 10px;border-radius:999px;font-size:11px;font-weight:800;text-transform:uppercase
}
.price-name{font-size:15px;color:var(--muted);text-transform:uppercase;letter-spacing:.12em}
.price-amount{font-size:48px;line-height:1;font-weight:800;margin:14px 0 6px}
.price-amount small{font-size:18px;color:var(--muted);font-weight:600}
.price-sub{color:var(--muted);font-size:14px;margin-bottom:18px}
.feature-list{display:grid;gap:10px;margin:18px 0 22px}
.feature-list div{font-size:14px;color:var(--muted)}
.feature-list div::before{content:'+';color:var(--gold);font-weight:800;margin-right:10px}
.packs{margin-top:18px}
.pack-card h3{font-size:18px}
.pack-price{font-size:34px;font-weight:800;margin:12px 0 6px}
.profit-grid{
  display:grid;grid-template-columns:1fr 1fr;gap:32px;align-items:stretch
}
.main-card{
  display:flex;flex-direction:column;justify-content:space-between;min-height:420px
}
.pricing-stack{
  display:flex;flex-direction:column;gap:16px;margin-top:22px
}
.pricing-row{
  display:flex;justify-content:space-between;align-items:center;gap:18px;
  padding:20px 24px;border-radius:12px;background:var(--panel-2);border:1px solid var(--line)
}
.pricing-row span{color:var(--muted)}
.pricing-row strong{font-size:20px;text-align:right}
.profit-box{margin-top:16px;padding:24px;border-radius:14px;display:flex;justify-content:space-between;align-items:center;gap:18px;flex-wrap:wrap;border:1px solid rgba(108,224,166,.24);background:rgba(108,224,166,.08)}
.profit-box span{color:#bdeed4}
.profit-box strong{font-size:22px;text-align:right}
.card-copy{display:flex;flex-direction:column;justify-content:space-between;flex:1}
.cta{
  text-align:center;padding:92px 0 110px
}
.cta-box{
  padding:44px;border-radius:32px;background:
    linear-gradient(180deg,rgba(215,179,93,.12),rgba(215,179,93,.04));
  border:1px solid rgba(215,179,93,.2)
}
.cta h2{font-size:clamp(34px,5vw,60px);line-height:1.04;letter-spacing:-.05em}
.cta p{max-width:650px;margin:16px auto 28px;color:var(--muted);font-size:17px}
footer{border-top:1px solid var(--line);padding:26px 0 34px}
.foot{display:flex;justify-content:space-between;gap:18px;align-items:center;color:var(--muted);font-size:14px;flex-wrap:wrap}.foot-links{display:flex;gap:14px;flex-wrap:wrap}
@media (max-width:900px){
  .profit-grid{grid-template-columns:1fr}
}
@media (max-width:980px){
  .hero-grid,.profit-grid,.pricing-wrap,.grid-4,.workflow,.grid-3,.grid-2{grid-template-columns:1fr}
  .section-head,.foot{display:block}
  .section-head p{margin-top:10px}
}
@media (max-width:720px){
  .nav-links{display:none}
  .nav-actions .btn-secondary{display:none}
  h1{font-size:42px}
  .price-amount{font-size:40px}
}
</style>
</head>
<body>
<nav>
  <div class="wrap nav-in">
    <a href="/" class="logo">VibeNote<span>.studio</span></a>
    <div class="nav-links">
      <a href="#fit">Use Cases</a>
      <a href="#workflow">Workflow</a>
      <a href="#pricing">Pricing</a>
      <a href="#deploy">Deploy</a>
    </div>
    <div class="nav-actions">
      <a href="/login" class="btn btn-secondary">Sign In</a>
      <a href="/signup" class="btn btn-primary">Start Free</a>
    </div>
  </div>
</nav>

<section class="hero">
  <div class="wrap hero-grid">
    <div>
      <div class="eyebrow">Agency Delivery System</div>
      <h1>Handle small client websites without wasting agency time.</h1>
      <p>VibeNote helps agencies stop rejecting small website work. Fill a structured brief, generate a clean static site, make chat-based edits, and deploy it live in minutes.</p>
      <div class="hero-actions">
        <a href="/signup" class="btn btn-primary">Deliver Your First Site</a>
        <a href="#pricing" class="btn btn-secondary">See Pricing</a>
      </div>
      <div class="mini-row">
        <div class="mini-pill">Don't say no to small clients</div>
        <div class="mini-pill">Built for landing pages and brochure sites</div>
        <div class="mini-pill">Static HTML, CSS and JS output</div>
      </div>
    </div>

    <div class="hero-card">
      <div class="dashboard-preview">
        <div class="preview-top">
          <h3>Agency dashboard language</h3>
          <div class="stat-row">
            <div class="stat">
              <div class="stat-label">Projects</div>
              <div class="stat-value">24</div>
            </div>
            <div class="stat">
              <div class="stat-label">Generated</div>
              <div class="stat-value">11</div>
            </div>
            <div class="stat">
              <div class="stat-label">Live</div>
              <div class="stat-value">7</div>
            </div>
          </div>
        </div>
        <div class="preview-list">
          <div class="project-row">
            <div class="project-meta">
              <strong>Akash Dental Care</strong>
              <span>Small business website</span>
            </div>
            <div class="badge generated">Generated</div>
          </div>
          <div class="project-row">
            <div class="project-meta">
              <strong>Studio Sanaa</strong>
              <span>Portfolio website</span>
            </div>
            <div class="badge editing">Editing</div>
          </div>
          <div class="project-row">
            <div class="project-meta">
              <strong>Urban Build Works</strong>
              <span>Brochure website</span>
            </div>
            <div class="badge live">Live</div>
          </div>
        </div>
        <div class="preview-math">
          <p><strong>Typical agency math:</strong> client pays &#8377;15,000 to &#8377;40,000, VibeNote Hosted Deploy costs &#8377;4,500, agency keeps the rest as profit.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<section id="fit">
  <div class="wrap">
    <div class="section-head">
      <div>
        <h2>Built for small websites your agency should deliver fast.</h2>
      </div>
      <p>VibeNote is best when the job needs to be shipped quickly, look polished, and not consume the same energy you reserve for bigger retainers and higher-value builds.</p>
    </div>
    <div class="grid-4">
      <div class="card type-card">
        <div class="icon">1</div>
        <h3>Landing pages</h3>
        <p>Campaign pages, launch pages, lead capture pages, and focused one-page sites.</p>
      </div>
      <div class="card type-card">
        <div class="icon">2</div>
        <h3>Brochure websites</h3>
        <p>Simple multi-section brochure sites for service businesses and local brands.</p>
      </div>
      <div class="card type-card">
        <div class="icon">3</div>
        <h3>Small business websites</h3>
        <p>Agency-friendly delivery for clinics, consultants, salons, builders, and local businesses.</p>
      </div>
      <div class="card type-card">
        <div class="icon">4</div>
        <h3>Portfolio websites</h3>
        <p>Personal brands, creators, freelancers, photographers, and professional portfolios.</p>
      </div>
    </div>
  </div>
</section>

<section class="not-for">
  <div class="wrap">
    <div class="section-head">
      <div>
        <h2>Clear fit means cleaner expectations.</h2>
      </div>
      <p>VibeNote is not meant to replace your product engineering team or custom app work. It is intentionally focused on static client website delivery.</p>
    </div>
    <div class="grid-3">
      <div class="card">
        <div class="icon">x</div>
        <h3>Not for ecommerce websites</h3>
        <p>Complex catalogs, carts, checkout flows, inventory, and payment logic are outside the intended scope.</p>
      </div>
      <div class="card">
        <div class="icon">x</div>
        <h3>Not for database-driven apps</h3>
        <p>Anything requiring dashboards, user accounts, custom data models, or backend workflows should stay in your normal dev pipeline.</p>
      </div>
      <div class="card">
        <div class="icon">x</div>
        <h3>Not for complex SaaS platforms</h3>
        <p>This is a delivery system for agency client sites, not a replacement for full SaaS product design and engineering.</p>
      </div>
    </div>
  </div>
</section>

<section id="workflow">
  <div class="wrap">
    <div class="section-head">
      <div>
        <h2>Simple workflow. Agency-friendly output.</h2>
      </div>
      <p>Reduce handoffs and long revision cycles with a tighter flow designed around how small client sites actually get delivered.</p>
    </div>
    <div class="workflow">
      <div class="card step">
        <div class="step-num">1</div>
        <h3>Fill structured brief</h3>
        <p>Capture business info, services, brand direction, content, contact details, and assets in one consistent workflow.</p>
      </div>
      <div class="card step">
        <div class="step-num">2</div>
        <h3>Generate website</h3>
        <p>Turn the brief into a client-ready static website without wiring up a custom frontend project.</p>
      </div>
      <div class="card step">
        <div class="step-num">3</div>
        <h3>Chat based edits</h3>
        <p>Ask for revisions in plain language and keep moving instead of rebuilding sections by hand.</p>
      </div>
      <div class="card step">
        <div class="step-num">4</div>
        <h3>Deploy live</h3>
        <p>Export to client hosting or use hosted deployment paths to push the static site live and hand over a URL.</p>
      </div>
    </div>
    <div class="stack-note">
      Websites are generated as clean static HTML, CSS and JS so they stay easy to export, review, host, and redeploy.
    </div>
  </div>
</section>

<section id="pricing">
  <div class="wrap">
    <div class="section-head">
      <div>
        <h2>Per-site yearly pricing for agency delivery.</h2>
      </div>
      <p>Choose the workflow that fits how you deliver small client websites, then move to agency packs when you are handling volume.</p>
    </div>

    <div class="pricing-wrap">
      <div class="card price-card">
        <div class="price-name">FTP Export Plan</div>
        <div class="price-amount">&#8377;2,000 <small>/ site / year</small></div>
        <div class="price-sub">Best when you want to hand over files or deploy to client hosting via FTP.</div>
        <div class="feature-list">
          <div>Generate website</div>
          <div>Unlimited edits</div>
          <div>Download full HTML CSS JS</div>
          <div>FTP deploy to client hosting</div>
          <div>Access for 1 year</div>
        </div>
        <a href="/signup" class="btn btn-secondary">Start With FTP Export</a>
      </div>

      <div class="card price-card popular">
        <div class="popular-tag">Most Popular</div>
        <div class="price-name">Hosted Deploy Plan</div>
        <div class="price-amount">&#8377;4,500 <small>/ site / year</small></div>
        <div class="price-sub">Best for agencies that want one-click deployment and a faster delivery handoff.</div>
        <div class="feature-list">
          <div>Generate website</div>
          <div>Unlimited edits</div>
          <div>One click deploy</div>
          <div>VibeNote hosting</div>
          <div>Free SSL</div>
          <div>Custom domain support</div>
          <div>1 year hosting</div>
        </div>
        <a href="/signup" class="btn btn-primary">Start Hosted Deploy</a>
      </div>
    </div>

    <div class="packs">
      <div class="section-head">
        <div>
          <h2>Agency packs for repeat delivery.</h2>
        </div>
        <p>These packs are for agencies delivering multiple client websites and wanting better economics across the year.</p>
      </div>
      <div class="grid-2">
        <div class="card pack-card">
          <h3>10 sites pack</h3>
          <div class="pack-price">&#8377;35,000 <small style="font-size:15px;color:var(--muted);font-weight:600">/ year</small></div>
          <p>For agencies closing a steady stream of landing pages, brochure sites, and other small client website work.</p>
        </div>
        <div class="card pack-card">
          <h3>50 sites pack</h3>
          <div class="pack-price">&#8377;1,50,000 <small style="font-size:15px;color:var(--muted);font-weight:600">/ year</small></div>
          <p>For teams using VibeNote as an internal delivery system for multiple small client websites all year long.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<section>
  <div class="wrap profit-grid">
    <div class="card main-card">
      <div class="card-copy">
        <div class="section-head" style="margin-bottom:14px">
          <div>
            <h2>Typical agency profit math.</h2>
          </div>
        </div>
        <p>When the client sees a polished website and your team keeps delivery lean, the margin story becomes very simple.</p>
        <div class="pricing-stack">
          <div class="pricing-row">
            <span>Client project fee</span>
            <strong>&#8377;15,000 to &#8377;40,000</strong>
          </div>
          <div class="pricing-row">
            <span>VibeNote Hosted Deploy cost</span>
            <strong>&#8377;4,500</strong>
          </div>
        </div>
      </div>
      <div class="profit-box">
        <span>Agency keeps the rest</span>
        <strong>Profit stays with you</strong>
      </div>
    </div>

    <div class="card main-card" id="deploy">
      <div class="card-copy">
        <div class="section-head" style="margin-bottom:14px">
          <div>
            <h2>Deployment architecture is ready for one-click static hosting.</h2>
          </div>
        </div>
        <p>Generated websites are treated as deployable static site bundles so the product can support direct publishing after generation.</p>
        <div class="feature-list" style="margin-top:18px">
          <div>Static bundle prepared from generated HTML, CSS and JS</div>
          <div>Deploy action designed to return a live URL after publishing</div>
          <div>Provider path prepared for client FTP, Cloudflare Pages, Netlify, and hosted delivery</div>
          <div>Agency dashboard states aligned around Generated, Editing, and Live</div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="cta">
  <div class="wrap">
    <div class="cta-box">
      <h2>Built for agencies who don't want to say no to small clients.</h2>
      <p>Fill the brief, generate the website, make chat-based edits, and deliver a live client website without losing your week to low-ticket projects.</p>
      <a href="/signup" class="btn btn-primary">Start Free</a>
    </div>
  </div>
</section>

<footer>
  <div class="wrap foot">
    <div>VibeNote.studio by Noob{Dev} Technologies</div>
    <div>For landing pages, brochure websites, small business websites, and portfolio websites.</div>
    <div class="foot-links">
      <a href="/docs">Docs</a>
      <a href="/privacy">Privacy Policy</a>
      <a href="/terms">Terms of Service</a>
      <a href="/cookies">Cookie Policy</a>
    </div>
  </div>
</footer>
</body>
</html>




