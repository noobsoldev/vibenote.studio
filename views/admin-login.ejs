<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"><title>Admin Login — Vibenote</title>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{background:#0a0a0a;color:#e8e8e8;font-family:'Poppins',sans-serif;min-height:100vh;display:flex;align-items:center;justify-content:center}
.card{background:#111;border:1px solid #1e1e1e;border-radius:16px;padding:40px;width:380px}
.logo{font-size:16px;font-weight:700;margin-bottom:24px;text-align:center}.logo span{color:#c9a84c}
h1{font-size:18px;font-weight:700;margin-bottom:4px;text-align:center}
.sub{color:#666;font-size:13px;text-align:center;margin-bottom:24px}
.field{margin-bottom:14px}
label{display:block;font-size:12px;color:#666;margin-bottom:5px}
input{width:100%;padding:12px 14px;background:#1a1a1a;border:1px solid #222;border-radius:8px;color:#e8e8e8;font-family:'Poppins',sans-serif;font-size:14px;outline:none}
input:focus{border-color:#c9a84c}
.btn{width:100%;padding:13px;background:#c9a84c;color:#0a0a0a;border:none;border-radius:10px;font-size:14px;font-weight:700;cursor:pointer;font-family:'Poppins',sans-serif;margin-top:4px}
.err{background:#2d1a1a;border:1px solid #5a1a1a;color:#ff7070;border-radius:8px;padding:12px;font-size:13px;margin-bottom:16px}
</style>
</head>
<body>
<div class="card">
  <div class="logo">Vibenote<span>.studio</span></div>
  <h1>Admin Access</h1>
  <p class="sub">Internal only</p>
  <% if (error) { %><div class="err"><%= error %></div><% } %>
  <form method="POST" action="/admin/login">
    <div class="field"><label>Email</label><input type="email" name="email" required></div>
    <div class="field"><label>Password</label><input type="password" name="password" required></div>
    <button class="btn" type="submit">Sign In →</button>
  </form>
</div>
</body>
</html>
