<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= agency.agency_name || agency.name %> - Website Information Form</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{--brand:<%= agency.brand_color || '#0f766e' %>;--bg:#f4f6f8;--panel:#ffffff;--text:#10212b;--muted:#617180;--line:#d7dde4}
body{font-family:system-ui,-apple-system,Segoe UI,sans-serif;background:linear-gradient(180deg,#eef2f6 0%,#f8fafb 100%);color:var(--text);line-height:1.6}
.wrap{max-width:860px;margin:0 auto;padding:32px 20px 64px}
.card{background:var(--panel);border:1px solid var(--line);border-radius:24px;padding:30px;box-shadow:0 18px 60px rgba(16,33,43,.08)}
.brand-head{display:flex;align-items:center;gap:16px;margin-bottom:24px}
.logo{width:72px;height:72px;border-radius:18px;background:rgba(0,0,0,.04);display:flex;align-items:center;justify-content:center;overflow:hidden;flex-shrink:0}
.logo img{width:100%;height:100%;object-fit:cover}
.logo span{font-size:26px;font-weight:800;color:var(--brand)}
h1{font-size:30px;line-height:1.1;margin-bottom:6px}
.sub{color:var(--muted);font-size:15px}
.alert{padding:12px 14px;border-radius:14px;margin-bottom:18px;font-size:14px}
.alert-error{background:#fff1f1;color:#a11b1b;border:1px solid #f1c9c9}
.alert-success{background:#eefbf3;color:#17653c;border:1px solid #bfe5cd}
.section{border:1px solid var(--line);border-radius:20px;padding:20px;margin-bottom:18px;background:#fbfcfd}
.section-kicker{font-size:11px;font-weight:800;letter-spacing:.14em;text-transform:uppercase;color:var(--brand);margin-bottom:8px}
.section-title{font-size:22px;font-weight:700;margin-bottom:14px}
.grid{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.group{margin-bottom:16px}
.group.full{grid-column:1/-1}
label{display:block;font-size:12px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);margin-bottom:8px}
input,textarea{width:100%;border:1px solid var(--line);border-radius:14px;padding:13px 14px;font:inherit;color:var(--text);background:#fff}
textarea{min-height:110px;resize:vertical}
button{background:var(--brand);color:#fff;border:none;border-radius:999px;padding:14px 22px;font:inherit;font-weight:700;cursor:pointer}
button:hover{filter:brightness(.96)}
.footer{margin-top:22px;color:var(--muted);font-size:13px;text-align:center}
.note{font-size:13px;color:var(--muted);margin-top:4px}
@media (max-width:720px){.grid{grid-template-columns:1fr}.group.full{grid-column:auto}.brand-head{align-items:flex-start}}
</style>
</head>
<body>
<div class="wrap">
  <div class="card">
    <div class="brand-head">
      <div class="logo">
        <% if (agency.logo_url) { %>
        <img src="<%= agency.logo_url %>" alt="<%= agency.agency_name || agency.name %> logo">
        <% } else { %>
        <span><%= (agency.agency_name || agency.name || 'A').charAt(0).toUpperCase() %></span>
        <% } %>
      </div>
      <div>
        <h1><%= agency.agency_name || agency.name %></h1>
        <div style="font-size:20px;font-weight:700;margin-bottom:6px">Website Information Form</div>
        <div class="sub">Please provide the details needed to prepare your website.</div>
      </div>
    </div>

    <% if (error) { %>
    <div class="alert alert-error"><%= error %></div>
    <% } %>
    <% if (success) { %>
    <div class="alert alert-success"><%= success %></div>
    <% } %>

    <form method="POST" action="/brief/<%= agency.slug %>" enctype="multipart/form-data">
      <div class="section">
        <div class="section-kicker">Step 1</div>
        <div class="section-title">Business Information</div>
        <div class="grid">
          <div class="group full">
            <label>Business Name</label>
            <input type="text" name="business_name" value="<%= values.business_name || '' %>" required>
          </div>
          <div class="group full">
            <label>Services</label>
            <textarea name="services" placeholder="List services separated by commas or new lines"><%= values.services || '' %></textarea>
          </div>
          <div class="group full">
            <label>About Business</label>
            <textarea name="about_business"><%= values.about_business || '' %></textarea>
          </div>
        </div>
      </div>

      <div class="section">
        <div class="section-kicker">Step 2</div>
        <div class="section-title">Branding</div>
        <div class="grid">
          <div class="group">
            <label>Logo Upload</label>
            <input type="file" name="logo" accept="image/*">
            <div class="note">Logo max size: 2MB.</div>
          </div>
          <div class="group">
            <label>Images Upload</label>
            <input type="file" name="images" accept="image/*" multiple>
            <div class="note">Upload up to 6 images, 5MB each.</div>
          </div>
        </div>
      </div>

      <div class="section">
        <div class="section-kicker">Step 3</div>
        <div class="section-title">Contact Details</div>
        <div class="grid">
          <div class="group full">
            <label>Address</label>
            <input type="text" name="address" value="<%= values.address || '' %>">
          </div>
          <div class="group">
            <label>Phone</label>
            <input type="text" name="phone" value="<%= values.phone || '' %>">
          </div>
          <div class="group">
            <label>Email</label>
            <input type="email" name="email" value="<%= values.email || '' %>">
          </div>
          <div class="group">
            <label>Instagram</label>
            <input type="text" name="instagram" value="<%= values.instagram || '' %>">
          </div>
          <div class="group">
            <label>Facebook</label>
            <input type="text" name="facebook" value="<%= values.facebook || '' %>">
          </div>
          <div class="group">
            <label>LinkedIn</label>
            <input type="text" name="linkedin" value="<%= values.linkedin || '' %>">
          </div>
          <div class="group">
            <label>Twitter / X</label>
            <input type="text" name="twitter" value="<%= values.twitter || '' %>">
          </div>
        </div>
      </div>

      <div style="margin-top:10px;display:flex;justify-content:flex-end">
        <button type="submit">Submit Website Details</button>
      </div>
    </form>

    <div class="footer">This form helps your agency prepare your website.</div>
  </div>
</div>
</body>
</html>
