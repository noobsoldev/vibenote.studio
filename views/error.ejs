<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Error — Vibenote.studio</title>
<link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="auth-page">
  <div class="auth-box" style="text-align:center">
    <div class="auth-logo" style="margin-bottom:20px">Vibenote<span>.studio</span></div>
    <div style="font-size:48px;margin-bottom:16px">⚠</div>
    <h2 style="font-size:18px;margin-bottom:8px">Something went wrong</h2>
    <p style="font-size:13px;color:var(--text-dim);margin-bottom:24px"><%= message || 'An unexpected error occurred.' %></p>
    <a href="/dashboard" class="btn btn-gold">Back to Dashboard</a>
  </div>
</div>
</body>
</html>
